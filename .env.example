# Neo4j - local instance (Neo4j Desktop or Docker)
neo4j_url=bolt://localhost:7687
neo4j_username=neo4j
neo4j_password=your_password

# Groq
llm_provider=groq
groq_api_key=your_groq_key
groq_model=llama-3.3-70b-versatile

# Local OpenAI-compatible LLM server
local_llm_base_url=http://localhost:8080/v1
local_llm_api_key=local-key
local_llm_model=local-model

# ChromaDB
chroma_path=./chroma_db
chroma_collection=collection_demo
chroma_namespace=default

# KG pipeline
batch_size=10
extraction_mode=tool
schema_level=unconstrained
node_properties=off
relationship_properties=off

# Document indexing pipeline
document_input_path=data/raw
document_chunk_strategy=hybrid
document_image_resolution_scale=2
document_enable_picture_description=false
document_fixed_character_chunk_size=2000
document_fixed_character_chunk_overlap=200
document_hierarchical_merge_list_items=true
document_hybrid_tokenizer=BAAI/bge-small-en-v1.5
document_hybrid_max_tokens=450
document_hybrid_merge_peers=true
document_hybrid_image_mode=placeholder
document_hybrid_image_placeholder=
document_hybrid_mark_annotations=true
document_hybrid_include_annotations=true
document_embedding_model_name=BAAI/bge-small-en-v1.5
document_embedding_device=cpu
document_embedding_normalize_embeddings=true
document_chroma_reset_collection=false
